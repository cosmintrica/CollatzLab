# Copy this file to .env and fill in your local values.

COLLATZ_LLM_ENABLED=0
COLLATZ_LLM_PROVIDER=gemini
COLLATZ_LLM_SAFETY_MODE=review_only
GEMINI_MODEL=gemini-2.5-pro
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com

# Optional runtime overrides
# COLLATZ_LAB_HOST=127.0.0.1
# COLLATZ_LAB_PORT=8000
# COLLATZ_CPU_PARALLEL_BATCH_SIZE=2000000
# COLLATZ_GPU_BATCH_SIZE=10000000
# COLLATZ_GPU_THREADS_PER_BLOCK=256
